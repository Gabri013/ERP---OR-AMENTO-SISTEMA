{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "sistema-os/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(?!.*\\.(js|css|svg|png|jpg|gif|woff|woff2|ico|txt|html)$).*",
      "dest": "/api/[...slug].js"
    }
  ]
}
