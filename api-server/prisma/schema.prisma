generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id            Int            @id @default(autoincrement())
  razaoSocial   String
  nomeFantasia  String?
  cnpjCpf       String?
  endereco      String?
  cidade        String?
  estado        String?
  telefone      String?
  email         String?
  observacoes   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  contasReceber ContaReceber[]
  orcamentos    Orcamento[]
  ordensServico OrdemServico[]
  vendas        Venda[]

  @@index([cnpjCpf])
  @@index([email])
}

model Usuario {
  id               Int                 @id @default(autoincrement())
  nome             String
  email            String              @unique
  senha            String
  tipo             TipoUsuario         @default(vendedor)
  setorId          Int?
  setor            Setor?              @relation(fields: [setorId], references: [id])
  status           String              @default("ativo")
  telefoneWhatsapp String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  osEtapas         OSEtapaProducao[]
  osHistoricos     OSHistoricoStatus[]
  osObservacoes    OSObservacao[]
  checklists       OSChecklist[]
  anexos           OSAnexo[]
  orcamentos       Orcamento[]
  pagamentos       Pagamento[]
  vendas           Venda[]
  auditLogs        AuditLog[]
  notificacoes     Notificacao[]
  refreshTokens    RefreshToken[]
  apontamentos     ApontamentoProducao[]
  revisoesEngenharia EngenhariaRevisao[]
  estoqueMovimentos EstoqueMovimentacao[]
  etiquetasImpressas EtiquetaIndustrial[]
  inspecoesQualidade InspecaoQualidade[]
  chamadosTecnicos AssistenciaTecnicaChamado[]

  @@index([tipo])
  @@index([setorId])
  @@index([email])
}

model Produto {
  id             Int             @id @default(autoincrement())
  codigo         String?
  nome           String
  descricao      String?
  foto           String?
  valor          Decimal         @db.Decimal(12, 2)
  estoque        Int             @default(0)
  status         String          @default("ativo")
  tipoProduto    String          @default("padrao")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orcamentoItens OrcamentoItem[]
  vendaItens     VendaItem[]
  estruturas     ProdutoEstrutura[]
  roteiros       ProdutoRoteiro[]
  revisoesEngenharia EngenhariaRevisao[]
}

model Setor {
  id           Int              @id @default(autoincrement())
  nome         String           @unique
  descricao    String?
  tipo         String
  usuarios     Usuario[]
  orcamentoSetores OrcamentoSetor[]
  capacidades   CapacidadeSetor[]
  roteiros      ProdutoRoteiro[]
  planosProducao PlanoProducao[]
  apontamentos  ApontamentoProducao[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  @@index([tipo])
}

model OrcamentoSetor {
  id           Int        @id @default(autoincrement())
  orcamentoId  Int
  orcamento    Orcamento  @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  setorId      Int
  setor        Setor      @relation(fields: [setorId], references: [id], onDelete: Cascade)
  criadoEm     DateTime   @default(now())

  @@unique([orcamentoId, setorId])
  @@index([orcamentoId])
  @@index([setorId])
}

model Orcamento {
  id               Int               @id @default(autoincrement())
  numero           String            @unique
  clienteId        Int
  usuarioId        Int
  dataOrcamento    DateTime
  validade         DateTime?
  valorTotal       Decimal           @db.Decimal(12, 2)
  desconto         Decimal           @default(0) @db.Decimal(12, 2)
  status           StatusOrcamento   @default(pendente)
  observacoes      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cliente          Cliente           @relation(fields: [clienteId], references: [id])
  usuario          Usuario           @relation(fields: [usuarioId], references: [id])
  itens            OrcamentoItem[]
  venda            Venda?
  orcamentoSetores OrcamentoSetor[]

  @@index([numero])
}

model OrcamentoItem {
  id              Int       @id @default(autoincrement())
  orcamentoId     Int
  produtoId       Int?
  descricaoManual String?
  quantidade      Decimal   @db.Decimal(10, 2)
  valorUnitario   Decimal   @db.Decimal(12, 2)
  valorTotal      Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  orcamento       Orcamento @relation(fields: [orcamentoId], references: [id])
  produto         Produto?  @relation(fields: [produtoId], references: [id])
}

model Venda {
  id               Int            @id @default(autoincrement())
  numero           String         @unique
  orcamentoId      Int?           @unique
  clienteId        Int
  usuarioId        Int
  dataVenda        DateTime
  valorTotal       Decimal        @db.Decimal(12, 2)
  desconto         Decimal        @default(0) @db.Decimal(12, 2)
  formaPagamento   String?
  numParcelas      Int            @default(1)
  status           StatusVenda    @default(em_andamento)
  observacoes      String?
  observacoesVenda String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contasReceber    ContaReceber[]
  ordensServico    OrdemServico[]
  cliente          Cliente        @relation(fields: [clienteId], references: [id])
  orcamento        Orcamento?     @relation(fields: [orcamentoId], references: [id])
  usuario          Usuario        @relation(fields: [usuarioId], references: [id])
  itens            VendaItem[]

  @@index([numero])
}

model VendaItem {
  id              Int       @id @default(autoincrement())
  vendaId         Int
  produtoId       Int?
  descricaoManual String?
  quantidade      Decimal   @db.Decimal(10, 2)
  valorUnitario   Decimal   @db.Decimal(12, 2)
  valorTotal      Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  produto         Produto?  @relation(fields: [produtoId], references: [id])
  venda           Venda     @relation(fields: [vendaId], references: [id])
  anexos          OSAnexo[]
}

model OrdemServico {
  id                    Int                 @id @default(autoincrement())
  numero                String              @unique
  vendaId               Int?
  clienteId             Int
  dataInicio            DateTime
  dataTermino           DateTime?
  prioridade            Prioridade          @default(verde)
  status                StatusOS            @default(pendente)
  etapaAtual            EtapaProducao       @default(autorizacao)
  observacoesGerais     String?
  observacoesCortedobra String?
  observacoesSolda      String?
  arquivoProjeto        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  etapas                OSEtapaProducao[]
  historico             OSHistoricoStatus[]
  observacoes           OSObservacao[]
  checklists            OSChecklist[]
  anexos                OSAnexo[]
  planosProducao        PlanoProducao[]
  apontamentos          ApontamentoProducao[]
  etiquetas             EtiquetaIndustrial[]
  inspecoesQualidade    InspecaoQualidade[]
  naoConformidades      NaoConformidade[]
  estoqueMovimentos     EstoqueMovimentacao[]
  chamadosTecnicos      AssistenciaTecnicaChamado[]
  cliente               Cliente             @relation(fields: [clienteId], references: [id])
  venda                 Venda?              @relation(fields: [vendaId], references: [id])

  @@index([numero])
}

model OSObservacao {
  id         Int          @id @default(autoincrement())
  osId       Int
  tipoSetor  String
  observacao String
  usuarioId  Int?
  createdAt  DateTime     @default(now())
  os         OrdemServico @relation(fields: [osId], references: [id])
  usuario    Usuario?     @relation(fields: [usuarioId], references: [id])
}

model OSHistoricoStatus {
  id             Int          @id @default(autoincrement())
  osId           Int
  statusAnterior String?
  statusNovo     String
  observacao     String?
  usuarioId      Int?
  createdAt      DateTime     @default(now())
  os             OrdemServico @relation(fields: [osId], references: [id])
  usuario        Usuario?     @relation(fields: [usuarioId], references: [id])
}

model OSEtapaProducao {
  id            Int           @id @default(autoincrement())
  osId          Int
  etapa         EtapaProducao
  status        String        @default("pendente")
  responsavel   String?
  lider         String?
  tempoEstimado Int?
  tempoReal     Int?
  observacao    String?
  dataInicio    DateTime?
  dataFim       DateTime?
  usuarioId     Int?
  createdAt     DateTime      @default(now())
  os            OrdemServico  @relation(fields: [osId], references: [id])
  usuario       Usuario?      @relation(fields: [usuarioId], references: [id])
}

model ContaReceber {
  id             Int         @id @default(autoincrement())
  vendaId        Int
  clienteId      Int
  parcelaNumero  Int
  totalParcelas  Int
  valorBruto     Decimal     @db.Decimal(12, 2)
  valorLiquido   Decimal     @db.Decimal(12, 2)
  valorRecebido  Decimal     @default(0) @db.Decimal(12, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  formaPagamento String?
  status         StatusConta @default(PENDENTE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  venda          Venda       @relation(fields: [vendaId], references: [id])
  pagamentos     Pagamento[]
}

model ContaPagar {
  id             Int         @id @default(autoincrement())
  descricao      String
  fornecedor     String?
  valor          Decimal     @db.Decimal(12, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusConta @default(PENDENTE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  razaoSocial String
  nomeFantasia String?
  cnpjCpf     String?
  email       String?
  telefone    String?
  cidade      String?
  estado      String?
  status      String   @default("ativo")
  homologado  Boolean  @default(false)
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  materiais   Material[]
  pedidosCompra CompraPedido[]

  @@index([cnpjCpf])
  @@index([status])
}

model Material {
  id             Int      @id @default(autoincrement())
  codigo         String   @unique
  descricao      String
  categoria      String
  unidade        String
  especificacao  String?
  estoqueMinimo  Decimal  @default(0) @db.Decimal(12, 3)
  estoqueAtual   Decimal  @default(0) @db.Decimal(12, 3)
  estoqueReservado Decimal @default(0) @db.Decimal(12, 3)
  localizacao    String?
  lotePadrao     String?
  custoMedio     Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("ativo")
  fornecedorId   Int?
  fornecedor     Fornecedor? @relation(fields: [fornecedorId], references: [id])
  estruturas     ProdutoEstrutura[]
  movimentos     EstoqueMovimentacao[]
  compraItens    CompraPedidoItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([categoria])
  @@index([status])
  @@index([fornecedorId])
}

model EstoqueMovimentacao {
  id          Int      @id @default(autoincrement())
  materialId  Int
  osId        Int?
  usuarioId   Int?
  tipo        TipoMovimentacaoEstoque
  quantidade  Decimal  @db.Decimal(12, 3)
  lote        String?
  localizacao String?
  documento   String?
  observacao  String?
  createdAt   DateTime @default(now())
  material    Material @relation(fields: [materialId], references: [id])
  os          OrdemServico? @relation(fields: [osId], references: [id])
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([materialId])
  @@index([osId])
  @@index([tipo])
  @@index([createdAt])
}

model ProdutoEstrutura {
  id          Int      @id @default(autoincrement())
  produtoId   Int
  materialId  Int
  quantidade  Decimal  @db.Decimal(12, 3)
  perdaPercentual Decimal @default(0) @db.Decimal(5, 2)
  revisao      String   @default("A")
  observacao   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  produto      Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  material     Material @relation(fields: [materialId], references: [id])

  @@index([produtoId])
  @@index([materialId])
}

model ProdutoRoteiro {
  id              Int      @id @default(autoincrement())
  produtoId       Int
  setorId         Int
  operacao        String
  sequencia       Int
  tempoPadraoMin  Int
  setupMin        Int      @default(0)
  recurso         String?
  instrucoes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  produto         Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  setor           Setor    @relation(fields: [setorId], references: [id])

  @@unique([produtoId, sequencia])
  @@index([produtoId])
  @@index([setorId])
}

model EngenhariaRevisao {
  id          Int      @id @default(autoincrement())
  produtoId   Int
  usuarioId   Int?
  revisao     String
  status      String   @default("rascunho")
  descricao   String?
  desenhoUrl  String?
  solidworksUrl String?
  pdfUrl      String?
  aprovadoEm  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  produto     Produto  @relation(fields: [produtoId], references: [id])
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@unique([produtoId, revisao])
  @@index([status])
}

model CapacidadeSetor {
  id            Int      @id @default(autoincrement())
  setorId        Int
  data           DateTime
  turno          String   @default("A")
  capacidadeMin  Int
  cargaPlanejadaMin Int @default(0)
  status         String   @default("operando")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  setor          Setor    @relation(fields: [setorId], references: [id])

  @@unique([setorId, data, turno])
  @@index([data])
  @@index([status])
}

model PlanoProducao {
  id            Int      @id @default(autoincrement())
  osId          Int
  setorId       Int
  sequencia     Int
  dataPlanejada DateTime
  inicioPrevisto DateTime?
  fimPrevisto    DateTime?
  prioridade     Int      @default(3)
  status         String   @default("planejado")
  cargaMin       Int      @default(0)
  observacao     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  os             OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  setor          Setor @relation(fields: [setorId], references: [id])

  @@unique([osId, setorId, sequencia])
  @@index([dataPlanejada])
  @@index([status])
  @@index([setorId])
}

model ApontamentoProducao {
  id          Int      @id @default(autoincrement())
  osId        Int
  setorId     Int
  usuarioId   Int?
  operacao    String
  inicio      DateTime
  fim         DateTime?
  tempoMin    Int?
  quantidade  Decimal  @default(1) @db.Decimal(12, 3)
  retrabalho  Boolean  @default(false)
  status      String   @default("em_andamento")
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  setor       Setor @relation(fields: [setorId], references: [id])
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([osId])
  @@index([setorId])
  @@index([usuarioId])
  @@index([status])
}

model InspecaoQualidade {
  id          Int      @id @default(autoincrement())
  osId        Int
  usuarioId   Int?
  etapa       String
  resultado   String   @default("pendente")
  checklist   Json?
  observacao  String?
  inspecionadoEm DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  naoConformidades NaoConformidade[]

  @@index([osId])
  @@index([resultado])
}

model NaoConformidade {
  id          Int      @id @default(autoincrement())
  osId        Int
  inspecaoId  Int?
  tipo        String
  severidade  String   @default("media")
  descricao   String
  acaoCorretiva String?
  status      String   @default("aberta")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  inspecao    InspecaoQualidade? @relation(fields: [inspecaoId], references: [id])

  @@index([osId])
  @@index([status])
  @@index([severidade])
}

model CompraPedido {
  id           Int      @id @default(autoincrement())
  numero       String   @unique
  fornecedorId Int?
  dataPedido   DateTime @default(now())
  previsaoEntrega DateTime?
  status       String   @default("aberto")
  valorTotal   Decimal  @default(0) @db.Decimal(12, 2)
  observacao   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  itens        CompraPedidoItem[]

  @@index([status])
  @@index([fornecedorId])
}

model CompraPedidoItem {
  id          Int      @id @default(autoincrement())
  pedidoId    Int
  materialId  Int?
  descricao   String
  quantidade  Decimal @db.Decimal(12, 3)
  valorUnitario Decimal @default(0) @db.Decimal(12, 2)
  valorTotal  Decimal @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  pedido      CompraPedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  material    Material? @relation(fields: [materialId], references: [id])

  @@index([pedidoId])
  @@index([materialId])
}

model EtiquetaIndustrial {
  id          Int      @id @default(autoincrement())
  osId        Int
  usuarioId   Int?
  codigo      String   @unique
  tipo        String   @default("os")
  setorAtual  String
  qrPayload   String
  barcode     String
  impressora  String?
  impressoEm  DateTime?
  reimpressao Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([osId])
  @@index([setorAtual])
}

model AssistenciaTecnicaChamado {
  id          Int      @id @default(autoincrement())
  numero      String   @unique
  osId        Int?
  clienteId   Int?
  usuarioId   Int?
  assunto     String
  descricao   String?
  status      String   @default("aberto")
  prioridade  String   @default("normal")
  abertoEm    DateTime @default(now())
  encerradoEm DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  os          OrdemServico? @relation(fields: [osId], references: [id])
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([osId])
  @@index([status])
}

model Pagamento {
  id             Int          @id @default(autoincrement())
  contaReceberId Int
  usuarioId      Int
  valorPago      Decimal      @db.Decimal(12, 2)
  formaPagamento String
  observacao     String?
  createdAt      DateTime     @default(now())
  contaReceber   ContaReceber @relation(fields: [contaReceberId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
}

enum StatusOrcamento {
  pendente
  em_projeto
  em_revisao
  em_producao
  concluida
  cancelada
  convertido
}

enum StatusVenda {
  em_andamento
  concluida
  cancelada
}

enum StatusOS {
  pendente
  liberada
  em_projeto
  em_revisao
  em_producao
  pausado
  concluida
  entregue
  cancelada
}

enum StatusConta {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
  PARCIALMENTE_PAGO
  RENEGOCIADO
}

enum Prioridade {
  verde
  amarelo
  vermelho
}

enum EtapaProducao {
  programacao
  engenharia
  corte
  dobra
  tubo
  solda
  coccao
  refrigeracao
  mobiliario
  montagem
  revisao
  embalagem
  expedicao
  autorizacao
  acabamento
  finalizacao
  concluida
  entregue
}

enum TipoUsuario {
  master
  gerente
  gestor_vendas
  vendedor
  financeiro
  engenharia
  producao
  corte
  dobra
  solda
  montagem
  visualizador
  projetista
  consultor
  dashboard_producao
  refrigeracao
  acabamento
  finalizacao
}

enum TipoMovimentacaoEstoque {
  entrada
  saida
  reserva
  consumo_os
  inventario
  ajuste
  estorno
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  acao        String
  modulo      String
  registroId  String?
  tabela      String?
  valorAntigo String?
  valorNovo   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model Permissao {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  modulo      String
  acoes       String[]
  createdAt   DateTime @default(now())
  roles       RolePermissao[]
}

model RolePermissao {
  id           Int        @id @default(autoincrement())
  tipoUsuario  TipoUsuario
  permissaoId  Int
  permissao    Permissao  @relation(fields: [permissaoId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([tipoUsuario, permissaoId])
}

model Notificacao {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  titulo      String
  mensagem    String
  tipo        String   // info, warning, success, error
  lida        Boolean  @default(false)
  link        String?  // Link opcional para redirecionamento
  createdAt   DateTime @default(now())
  readAt      DateTime?
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OSChecklist {
  id          Int          @id @default(autoincrement())
  osId        Int
  etapa       String
  item        String
  concluido   Boolean      @default(false)
  obrigatorio Boolean      @default(false)
  usuarioId   Int?
  concluidoEm DateTime?
  createdAt   DateTime     @default(now())
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  usuario     Usuario?     @relation(fields: [usuarioId], references: [id])
}

model OSAnexo {
  id          Int          @id @default(autoincrement())
  osId        Int
  vendaItemId Int?
  nome        String
  url         String?
  conteudo    Bytes?
  mimeType    String?
  tamanho     Int?
  tipo        String       @default("outro")
  descricao   String?
  usuarioId   Int?
  createdAt   DateTime     @default(now())
  os          OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  vendaItem   VendaItem?   @relation(fields: [vendaItemId], references: [id], onDelete: SetNull)
  usuario     Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([osId])
  @@index([vendaItemId])
}
