generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id            Int            @id @default(autoincrement())
  razaoSocial   String
  nomeFantasia  String?
  cnpjCpf       String?
  endereco      String?
  cidade        String?
  estado        String?
  telefone      String?
  email         String?
  observacoes   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  contasReceber ContaReceber[]
  orcamentos    Orcamento[]
  ordensServico OrdemServico[]
  vendas        Venda[]
}

model Usuario {
  id               Int                 @id @default(autoincrement())
  nome             String
  email            String              @unique
  senha            String
  tipo             TipoUsuario         @default(vendedor)
  status           String              @default("ativo")
  telefoneWhatsapp String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  osEtapas         OSEtapaProducao[]
  osHistoricos     OSHistoricoStatus[]
  osObservacoes    OSObservacao[]
  orcamentos       Orcamento[]
  pagamentos       Pagamento[]
  vendas           Venda[]
  auditLogs        AuditLog[]
  notificacoes     Notificacao[]
  refreshTokens    RefreshToken[]
}

model Produto {
  id             Int             @id @default(autoincrement())
  codigo         String?
  nome           String
  descricao      String?
  foto           String?
  valor          Decimal         @db.Decimal(12, 2)
  estoque        Int             @default(0)
  status         String          @default("ativo")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orcamentoItens OrcamentoItem[]
  vendaItens     VendaItem[]
}

model Orcamento {
  id            Int             @id @default(autoincrement())
  numero        String          @unique
  clienteId     Int
  usuarioId     Int
  dataOrcamento DateTime
  validade      DateTime?
  valorTotal    Decimal         @db.Decimal(12, 2)
  desconto      Decimal         @default(0) @db.Decimal(12, 2)
  status        StatusOrcamento @default(pendente)
  observacoes   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cliente       Cliente         @relation(fields: [clienteId], references: [id])
  usuario       Usuario         @relation(fields: [usuarioId], references: [id])
  itens         OrcamentoItem[]
  venda         Venda?
}

model OrcamentoItem {
  id              Int       @id @default(autoincrement())
  orcamentoId     Int
  produtoId       Int?
  descricaoManual String?
  quantidade      Decimal   @db.Decimal(10, 2)
  valorUnitario   Decimal   @db.Decimal(12, 2)
  valorTotal      Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  orcamento       Orcamento @relation(fields: [orcamentoId], references: [id])
  produto         Produto?  @relation(fields: [produtoId], references: [id])
}

model Venda {
  id               Int            @id @default(autoincrement())
  numero           String         @unique
  orcamentoId      Int?           @unique
  clienteId        Int
  usuarioId        Int
  dataVenda        DateTime
  valorTotal       Decimal        @db.Decimal(12, 2)
  desconto         Decimal        @default(0) @db.Decimal(12, 2)
  formaPagamento   String?
  numParcelas      Int            @default(1)
  status           StatusVenda    @default(em_andamento)
  observacoes      String?
  observacoesVenda String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contasReceber    ContaReceber[]
  ordensServico    OrdemServico[]
  cliente          Cliente        @relation(fields: [clienteId], references: [id])
  orcamento        Orcamento?     @relation(fields: [orcamentoId], references: [id])
  usuario          Usuario        @relation(fields: [usuarioId], references: [id])
  itens            VendaItem[]
}

model VendaItem {
  id              Int      @id @default(autoincrement())
  vendaId         Int
  produtoId       Int?
  descricaoManual String?
  quantidade      Decimal  @db.Decimal(10, 2)
  valorUnitario   Decimal  @db.Decimal(12, 2)
  valorTotal      Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  produto         Produto? @relation(fields: [produtoId], references: [id])
  venda           Venda    @relation(fields: [vendaId], references: [id])
}

model OrdemServico {
  id                    Int                 @id @default(autoincrement())
  numero                String              @unique
  vendaId               Int?
  clienteId             Int
  dataInicio            DateTime
  dataTermino           DateTime?
  prioridade            Prioridade          @default(verde)
  status                StatusOS            @default(pendente)
  etapaAtual            EtapaProducao       @default(autorizacao)
  observacoesGerais     String?
  observacoesCortedobra String?
  observacoesSolda      String?
  arquivoProjeto        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  etapas                OSEtapaProducao[]
  historico             OSHistoricoStatus[]
  observacoes           OSObservacao[]
  cliente               Cliente             @relation(fields: [clienteId], references: [id])
  venda                 Venda?              @relation(fields: [vendaId], references: [id])
}

model OSObservacao {
  id         Int          @id @default(autoincrement())
  osId       Int
  tipoSetor  String
  observacao String
  usuarioId  Int?
  createdAt  DateTime     @default(now())
  os         OrdemServico @relation(fields: [osId], references: [id])
  usuario    Usuario?     @relation(fields: [usuarioId], references: [id])
}

model OSHistoricoStatus {
  id             Int          @id @default(autoincrement())
  osId           Int
  statusAnterior String?
  statusNovo     String
  observacao     String?
  usuarioId      Int?
  createdAt      DateTime     @default(now())
  os             OrdemServico @relation(fields: [osId], references: [id])
  usuario        Usuario?     @relation(fields: [usuarioId], references: [id])
}

model OSEtapaProducao {
  id         Int           @id @default(autoincrement())
  osId       Int
  etapa      EtapaProducao
  status     String        @default("pendente")
  dataInicio DateTime?
  dataFim    DateTime?
  usuarioId  Int?
  createdAt  DateTime      @default(now())
  os         OrdemServico  @relation(fields: [osId], references: [id])
  usuario    Usuario?      @relation(fields: [usuarioId], references: [id])
}

model ContaReceber {
  id             Int         @id @default(autoincrement())
  vendaId        Int
  clienteId      Int
  parcelaNumero  Int
  totalParcelas  Int
  valorBruto     Decimal     @db.Decimal(12, 2)
  valorLiquido   Decimal     @db.Decimal(12, 2)
  valorRecebido  Decimal     @default(0) @db.Decimal(12, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  formaPagamento String?
  status         StatusConta @default(PENDENTE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  venda          Venda       @relation(fields: [vendaId], references: [id])
  pagamentos     Pagamento[]
}

model ContaPagar {
  id             Int         @id @default(autoincrement())
  descricao      String
  fornecedor     String?
  valor          Decimal     @db.Decimal(12, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusConta @default(PENDENTE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Pagamento {
  id             Int          @id @default(autoincrement())
  contaReceberId Int
  usuarioId      Int
  valorPago      Decimal      @db.Decimal(12, 2)
  formaPagamento String
  observacao     String?
  createdAt      DateTime     @default(now())
  contaReceber   ContaReceber @relation(fields: [contaReceberId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
}

enum StatusOrcamento {
  pendente
  em_projeto
  em_revisao
  em_producao
  concluida
  cancelada
  convertido
}

enum StatusVenda {
  em_andamento
  concluida
  cancelada
}

enum StatusOS {
  pendente
  em_projeto
  em_revisao
  em_producao
  concluida
  cancelada
}

enum StatusConta {
  PENDENTE
  PAGO
  ATRASADO
}

enum Prioridade {
  verde
  amarelo
  vermelho
}

enum EtapaProducao {
  autorizacao
  corte
  dobra
  solda
  refrigeracao
  acabamento
  finalizacao
  montagem
  concluida
}

enum TipoUsuario {
  master
  gerente
  vendedor
  producao
  financeiro
  engenharia
  visualizador
  // sector / production roles present in the database
  projetista
  dashboard_producao
  corte
  dobra
  solda
  refrigeracao
  acabamento
  finalizacao
  montagem
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  acao        String
  modulo      String
  registroId  String?
  tabela      String?
  valorAntigo String?
  valorNovo   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model Permissao {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  modulo      String
  acoes       String[]
  createdAt   DateTime @default(now())
  roles       RolePermissao[]
}

model RolePermissao {
  id           Int        @id @default(autoincrement())
  tipoUsuario  TipoUsuario
  permissaoId  Int
  permissao    Permissao  @relation(fields: [permissaoId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([tipoUsuario, permissaoId])
}

model Notificacao {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  titulo      String
  mensagem    String
  tipo        String   // info, warning, success, error
  lida        Boolean  @default(false)
  link        String?  // Link opcional para redirecionamento
  createdAt   DateTime @default(now())
  readAt      DateTime?
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
