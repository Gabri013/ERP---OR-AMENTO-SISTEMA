# Copy this file to .env and fill with your real values

# Neon Postgres connection string (get it from https://neon.tech)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT secret (generate a strong random string)
JWT_SECRET="change-this-to-a-very-long-random-string-for-production"

# Port for local dev
PORT=3000

# Allowed frontend origin for CORS (your Vercel frontend URL)
CORS_ORIGIN="http://localhost:5173,https://sistema-os-omega.vercel.app"
